<?xml version="1.0" encoding="utf-8"?><!--
    NFC 技术过滤器
    NTAG215 属于 NfcA 技术，同时也被识别为 MifareUltralight。
    TECH_DISCOVERED 优先级高于 TAG_DISCOVERED，
    可确保冷启动时系统直接唤起本 App，而非弹出系统 NFC 选择 UI。
-->
<resources xmlns:xliff="urn:oasis:names:tc:xliff:document:1.2">
    <!-- NfcA 覆盖所有符合 ISO14443-3A 的标签（NTAG213/215/216 等） -->
    <tech-list>
        <tech>android.nfc.tech.NfcA</tech>
    </tech-list>
    <!-- MifareUltralight 兼容（NTAG 系列在部分设备上以此协议识别） -->
    <tech-list>
        <tech>android.nfc.tech.MifareUltralight</tech>
    </tech-list>
</resources>
